# Supabase — preencha após conectar o projeto (local via `supabase start` ou na nuvem).
# Para o ambiente LOCAL, `supabase start` imprime estes valores.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=cole-a-anon-key-aqui

# Usada só no servidor (NUNCA exponha no client). Para scripts/admin.
SUPABASE_SERVICE_ROLE_KEY=cole-a-service-role-key-aqui
