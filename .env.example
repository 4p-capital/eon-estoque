NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InFxd2libnB5eWRjeGF6a3hkaWZnIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NTgyOTA5MjgsImV4cCI6MjA3Mzg2NjkyOH0.ajmb8Wib2iSOrqvr1lCxmzMyqrfkKcdkOLg11hhs43w

# Usada só no servidor (NUNCA exponha no client). Para scripts/admin.
SUPABASE_SERVICE_ROLE_KEY=cole-a-service-role-key-aqui

# URL pública do app (ex.: https://eon-estoque.vercel.app). Usada para montar o
# link que o QR do kit codifica (/k/<token>) — sem isso, no dev cai na origem atual.
NEXT_PUBLIC_SITE_URL=https://eon-estoque.vercel.app/

# Chave-mestra para cifrar os certificados A1 (.pfx) e senhas das SPEs.
# 32 bytes em base64. NUNCA versionar a real, NUNCA prefixo NEXT_PUBLIC.
# Gere com:  openssl rand -base64 32   (ou: node -e "console.log(crypto.randomBytes(32).toString('base64'))")
# ⚠️ Se perder/trocar esta chave, os certificados cifrados no banco ficam ilegíveis.
CERT_ENCRYPTION_KEY=gere-uma-chave-de-32-bytes-em-base64
